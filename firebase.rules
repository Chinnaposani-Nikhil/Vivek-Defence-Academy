rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // By default, only authenticated admins can read/write data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow public users to submit new enquiries to the enquiries collection
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Allow public users to submit new admissions to the admissions collection
    match /admissions/{admissionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
